# Server Configuration
PORT=8080
FRONTEND_URL=https://your-netlify-site.netlify.app

# MongoDB connection - Use MongoDB Atlas or local instance
MONGODB_URL=your_mongodb_connection_string_here

# Cloudinary - For storing generated images (get credentials at https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Hugging Face - image generation
HUGGINGFACE_TOKEN=your_huggingface_token
HF_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0

# Resend - API-based email service (signup at https://resend.com, free tier available)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@aimagegenerator.com